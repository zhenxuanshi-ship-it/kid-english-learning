# Optional deployment/runtime settings
# Usually injected automatically during build, but can be overridden.
VITE_APP_VERSION=0.1.0

# Leave empty to disable. Later can point to real Sentry DSN.
VITE_SENTRY_DSN=

# Leave empty to disable. Can be reused for Plausible/Umami/Vercel-style analytics integration.
VITE_ANALYTICS_SITE_ID=
